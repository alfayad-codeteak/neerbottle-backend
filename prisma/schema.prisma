// AquaFliq Water Ordering System – Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Authentication ----
model User {
  id           String    @id @default(cuid())
  phone        String    @unique
  passwordHash String?
  name         String?
  role         String    @default("customer")
  permissions  Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  refreshTokens RefreshToken[]
  addresses    Address[]
  orders       Order[]
  depositWallet UserDepositWallet?
  depositTransactions DepositTransaction[]
  deliveryPartner DeliveryPartner?
}

// ---- Addresses ----
model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String?  // e.g. "Home", "Office"
  line1     String
  line2     String?
  city      String
  state     String?
  pincode   String?
  phone     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  orders       Order[]
}

// ---- Products ----
model Product {
  id          String      @id @default(cuid())
  name        String
  price       Decimal     @db.Decimal(10, 2)
  photoUrl    String?
  photoUrls   String[]    @default([])
  stock       Int         @default(0)
  category    String?
  isActive    Boolean     @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  orderItems  OrderItem[]
}

// ---- Orders ----
model Order {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  addressId     String
  address       Address       @relation(fields: [addressId], references: [id], onDelete: Restrict)
  deliveryPartnerId String?
  deliveryPartner   DeliveryPartner? @relation(fields: [deliveryPartnerId], references: [id], onDelete: SetNull)
  assignedAt    DateTime?
  deliveryStatus String       @default("NONE")
  deliveryNotes  String?
  timeSlot      String
  paymentMethod String
  status        String        @default("RECEIVED")
  ifCanRefund   Boolean       @default(false)
  returnedCanCount Int        @default(0)
  totalAmount   Decimal       @db.Decimal(12, 2)
  depositBase   Decimal       @default(0) @db.Decimal(12, 2)
  depositDiscount Decimal     @default(0) @db.Decimal(12, 2)
  depositCharge Decimal       @default(0) @db.Decimal(12, 2)
  depositRefundedAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         OrderItem[]
  depositTransactions DepositTransaction[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([deliveryPartnerId])
}

model DeliveryPartner {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  vehicleType   String?
  vehicleNumber String?
  isAvailable   Boolean  @default(true)
  currentLat    Decimal? @db.Decimal(10, 7)
  currentLng    Decimal? @db.Decimal(10, 7)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]

  @@index([userId])
}

model DepositConfig {
  id             String   @id @default(cuid())
  enabled        Boolean  @default(true)
  perCanAmount   Decimal  @default(0) @db.Decimal(10, 2)
  promoActive    Boolean  @default(false)
  promoStartsAt  DateTime?
  promoEndsAt    DateTime?
  tiers          Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model UserDepositWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DepositTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type        String
  amount      Decimal  @db.Decimal(12, 2)
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@index([orderId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model OtpVerification {
  id        String   @id @default(cuid())
  phone    String
  code     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}
