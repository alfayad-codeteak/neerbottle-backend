# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL) – Supabase or any Postgres
# Supabase: use Session mode (port 5432). Port 6543 causes "prisma migrate dev" to hang.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?schema=public"

# Optional: Supabase project URL and anon key (for future Storage, Realtime, or Edge Functions)
# SUPABASE_URL=https://[PROJECT_REF].supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Owner: if set, first owner must send matching X-Owner-Secret on POST /auth/register-owner.
# Leave unset or empty for local/simple setup: first owner registers with phone + password only.
# OWNER_SECRET=your-owner-secret-change-in-production

# Redis (optional) – OTP codes stored in Redis with TTL when REDIS_URL or REDIS_HOST is set
# Docker Compose: REDIS_URL=redis://redis:6379
# Local: REDIS_URL=redis://localhost:6379
# REDIS_URL=
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# CORS: comma-separated origins for browser clients (default is localhost:3000–3005 if unset)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# MSG91 SMS (OTP Flow API). Set `MSG91_AUTH_KEY` in Cloudflare secrets for production.
# Template body example: ##otp## is your OTP for shopping at ##name##. — map `otp` + `name` in Flow.
# MSG91_AUTH_KEY=
# Optional overrides (defaults: template 69f592e0bd83b71e690c8cd2, shop name "FLIQ Water"):
# MSG91_TEMPLATE_ID=69f592e0bd83b71e690c8cd2
# MSG91_OTP_SHOP_NAME=FLIQ Water

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Razorpay (add when implementing payments)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
